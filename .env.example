JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=BitteAendern_2026!

# GID des Docker-Sockets (/var/run/docker.sock) auf dem Host. Wird im Container
# per group_add ergänzt, damit der jenkins-User docker-Befehle absetzen darf.
# Ermitteln:
#   Linux:  stat -c '%g' /var/run/docker.sock
#   macOS (Docker Desktop): docker run --rm -v /var/run/docker.sock:/var/run/docker.sock alpine stat -c '%g' /var/run/docker.sock
DOCKER_GID=991
